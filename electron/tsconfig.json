{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "../dist-electron",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["*.ts"],
  "exclude": ["../server", "../client", "../shared"]
}
